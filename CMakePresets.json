{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (tests ON)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-O0 -g",
        "HOMESTEAD_BUILD_TESTS": "ON",
        "HOMESTEAD_BUILD_CLI": "OFF",
        "HOMESTEAD_ENABLE_LOGGING": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release (tests OFF)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O3 -DNDEBUG",
        "HOMESTEAD_BUILD_TESTS": "OFF",
        "HOMESTEAD_BUILD_CLI": "OFF",
        "HOMESTEAD_ENABLE_LOGGING": "OFF"
      }
    },
    {
      "name": "sanitize",
      "displayName": "Sanitize (ASan + UBSan, tests ON)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-O1 -g -fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "HOMESTEAD_BUILD_TESTS": "ON",
        "HOMESTEAD_BUILD_CLI": "OFF",
        "HOMESTEAD_ENABLE_LOGGING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": { "outputOnFailure": true }
    }
  ]
}
